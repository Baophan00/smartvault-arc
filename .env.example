# Circle API Keys — keep these secret!
# Get them from: https://console.circle.com/api-keys

# Kit Key — for App Kit SDK (Send, Bridge, Swap)
# Works on both testnet and mainnet
NEXT_PUBLIC_KIT_KEY=KIT_KEY:236f488b55bef9bd777053e7a0204787:ed648f67d9f23dc3223c385446eb27c4

# Client Key — for Modular Wallets SDK (passkey, create wallet)
NEXT_PUBLIC_CLIENT_KEY=TEST_CLIENT_KEY:d89592a20243e259dc609ed98fc1141c:cc2470bea182d02a8fd72398e6525d65

# Client URL — from Circle Console (Appearance → Client URL)
# Find this in Console → API & Client Keys → your client key → copy Client URL
NEXT_PUBLIC_CLIENT_URL=

# API Key — for server-side proxy (Circle REST API)
NEXT_PUBLIC_API_KEY=TEST_API_KEY:03e373d1426ad4ddbf6b39e65b201881:aee15bfb7d727dfe760cb92eb3eb3371
